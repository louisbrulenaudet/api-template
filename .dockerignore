# Allowlist approach: exclude everything by default, then re-include only what
# the Dockerfile explicitly COPYs. Any file or directory added to the project
# in the future is automatically kept out of the build context without further
# changes to this file.
*

# builder stage — uv sync --frozen --no-dev
!pyproject.toml
!uv.lock

# runtime stage — application source
!app/
!app/**
